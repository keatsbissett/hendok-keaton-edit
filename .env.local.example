# NEVER commit .env.local or any real secrets.
# All of these must also be set in Vercel for production.
# ============================================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

